<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Must_have_description</fullName>
    <active>true</active>
    <errorConditionFormula>LEN(Name)&lt;= 15</errorConditionFormula>
    <errorDisplayField>Name</errorDisplayField>
    <errorMessage
  >Your description must contain more than 15 characters</errorMessage>
</ValidationRule>
